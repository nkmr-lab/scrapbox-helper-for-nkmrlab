{
  "manifest_version": 3,
  "name": "Labo Scrapbox Helper",
  "version": "0.2.0",
  "description": "Scrapbox Helper for Research Labs: Calendars, Outlines, Minutes, and Project Histories",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://scrapbox.io/*"],
      "js": [
        "content/constants.js",
        "content/style.js",
        "content/config.js",
        "content/dom.js",
        "content/parser.js",
        "content/api.js",
        "content/pagewatcher.js",
        "content/stats.js",
        "content/history.js",
        "content/top_page.js",
        "content/research_note.js",
        "content/calendar.js",
        "content/todo.js",
        "content/experiment.js",
        "content/minutes.js",
        "content/paper_intro.js",
        "content/presentation.js",
        "content/watcher_manager.js",
        "content/main.js"
      ],
      "type": "module"
    }
  ]
}
